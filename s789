-- ============================================================
-- Helper — ดึง Level และ Wave ปัจจุบัน
-- ============================================================
local function getCurrentStats()
    local level = 0
    if GAME_ID == "anime_vanguards" then
        pcall(function()
            local lvlText = player.PlayerGui.Hotbar.Main.Level.Level.Text
            level = tonumber(lvlText:match("%d+")) or 0
        end)
    elseif GAME_ID == "anime_overload" then
        pcall(function()
            local lvlText = player.PlayerGui.ExperienceGui.container.levelFrame.bg.inside.levelAmount.Text
            level = tonumber(lvlText:match("%d+")) or 0
        end)
    elseif GAME_ID == "utdx" then
        pcall(function()
            local lvlText = player.PlayerGui.GameUI.HUD.Bottom.Hotbar.LevelBar.Level.Text
            level = tonumber(lvlText:match("Level (%d+)")) or 0
        end)
    end
    return level, lastWave
end

-- ============================================================
-- Send
-- ============================================================
local function sendToBackend(data)
    local timestamp = os.date("!%Y-%m-%dT%H:%M:%SZ")
    local level, wave = getCurrentStats()

    local payload = {
        username     = player.Name,
        userId       = player.UserId,
        serviceName  = GAME_NAME,
        gameId       = GAME_ID,
        progress     = 0,
        currentStats = { level = level, bp = 0 },
        matchInfo    = { map = data.file or "Unknown", wave = wave },
        endScreen    = {
            act      = data.act,
            file     = data.file,
            playTime = data.playTime,
            quantity = data.quantity,
        },
        recentLog = {
            act      = data.act,
            file     = data.file,
            playTime = data.playTime,
            quantity = data.quantity,
            status   = "COMPLETED",
            time     = timestamp,
            rewards  = data.quantity,
        },
    }
    local ok, response = pcall(function()
        return HttpService:RequestAsync({
            Url     = BACKEND_URL .. "/api/overload/update",
            Method  = "POST",
            Headers = { ["Content-Type"] = "application/json" },
            Body    = HttpService:JSONEncode(payload)
        })
    end)
    if ok and response.Success then
        print("[OV] ✅ Sent! Act=" .. tostring(data.act) .. " | File=" .. tostring(data.file) .. " | Time=" .. tostring(data.playTime) .. " | Rewards=" .. tostring(data.quantity) .. " | LVL=" .. level .. " | Wave=" .. wave)
    else
        warn("[OV] ❌ Send FAIL:", response and response.StatusCode)
    end
end

-- ============================================================
-- [Anime Overload] Scan Rewards (scroll-based)
-- ============================================================
local SKIP_NAMES = {
    layer1     = true,
    layer2     = true,
    layer3     = true,
    ImageLabel = true,
    Quantity   = true,
    isLoading  = true,
    InputArea  = true,
}

local function scanRewards_AO(scroll)
    local rewards = {}
    for _, frame in ipairs(scroll:GetChildren()) do
        for _, rarity in ipairs(frame:GetChildren()) do
            local qty = rarity:FindFirstChild("Quantity")
            local img = rarity:FindFirstChild("ImageLabel")
            if qty and qty.Text ~= "" and qty.Text ~= "0" then
                local itemName = nil
                if img then
                    itemName = getItemNameFromImage(img.Image)
                end
                if not itemName then
                    for _, sub in ipairs(rarity:GetChildren()) do
                        if sub:IsA("ImageLabel") and not SKIP_NAMES[sub.Name] then
                            itemName = sub.Name
                            break
                        end
                    end
                end
                local entry = itemName and (itemName .. " " .. qty.Text) or qty.Text
                table.insert(rewards, entry)
                print("[OV] reward →", entry)
            end
        end
    end
    return rewards
end

-- ============================================================
-- [Anime Vanguards] Scan Rewards (fixed nodes)
-- Path: EndScreen.Holder.Main.StageRewards.Main
--   Gold.Holder.Main.Amount  → e.g. "x100"
--   Gems.Holder.Main.Amount  → e.g. "x180"
--   GreenBean (folder)       → children each have Amount + ItemName
-- ============================================================
local function scanRewards_AV()
    local rewards = {}
    local ok, err = pcall(function()
        local sr = player.PlayerGui.EndScreen.Holder.Main.StageRewards.Main

        -- loop ทุก reward frame ไม่ hardcode
        for _, rewardFrame in ipairs(sr:GetChildren()) do
            if rewardFrame:IsA("Frame") then
                local main = rewardFrame:FindFirstChild("Holder")
                             and rewardFrame.Holder:FindFirstChild("Main")
                if main then
                    local amtLabel  = main:FindFirstChild("Amount")
                    local nameLabel = main:FindFirstChild("ItemName")
                    local amt  = amtLabel  and amtLabel.Text or ""
                    local name = nameLabel and nameLabel.Text or rewardFrame.Name
                    if amt ~= "" and amt ~= "x0" then
                        local entry = name .. " " .. amt
                        table.insert(rewards, entry)
                        print("[AV] reward →", entry)
                    end
                end
            end
        end
    end)
    if not ok then warn("[AV] scanRewards_AV error:", err) end
    return rewards
end

