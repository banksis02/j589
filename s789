-- ============================================================
-- [Anime Vanguards] SessionTimer + Wave Watcher
-- ============================================================
local function setupSessionTimer()
    local gui = player.PlayerGui
    -- SessionTimer
    local ok1, err1 = pcall(function()
        local sessionTimer = gui.HUD.Map.SessionTimer.Label
        sessionTimer:GetPropertyChangedSignal("Text"):Connect(function()
            if lockPlayTime then return end
            local t = sessionTimer.Text
            -- เก็บเฉพาะค่าที่มากกว่า 00:00 และไม่ใช่ค่าว่าง
            if t ~= "" and t ~= "00:00" and t ~= "00:00:00" then
                lastPlayTime = t
            end
            -- ถ้า reset กลับเป็น 00:00 ไม่ทับค่าเดิม (lastPlayTime ยังเป็นค่าเก่า)
        end)
        print("[AV] ✅ SessionTimer watcher ready!")
    end)
    if not ok1 then warn("[AV] SessionTimer error:", err1) end

    -- Wave
    local ok2, err2 = pcall(function()
        local wavesAmount = gui.HUD.Map.WavesAmount
        local function parseWave(text)
            -- ดึงตัวเลขสุดท้ายออกจาก RichText เช่น ">11</font>" หรือ ">15</font>"
            local nums = {}
            for n in text:gmatch(">(%d+)<") do
                table.insert(nums, tonumber(n))
            end
            -- ถ้าไม่มี tag ลอง match ตัวเลขธรรมดา
            if #nums == 0 then
                for n in text:gmatch("%d+") do
                    table.insert(nums, tonumber(n))
                end
            end
            -- เอาค่ามากสุด (wave total มักเป็นตัวสุดท้าย)
            local max = 0
            for _, v in ipairs(nums) do
                if v > max then max = v end
            end
            return max
        end

        wavesAmount:GetPropertyChangedSignal("Text"):Connect(function()
            if lockPlayTime then return end
            local w = parseWave(wavesAmount.Text)
            if w > 0 then lastWave = w end
        end)
        lastWave = parseWave(wavesAmount.Text)
        print("[AV] ✅ Wave watcher ready! Current wave:", lastWave)
    end)
    if not ok2 then warn("[AV] Wave watcher error:", err2) end
end
task.spawn(function()
    task.wait(5)
    if GAME_ID == "anime_overload" then
        setupWatchers_AO()
        setupRewardWatcher_AO()
        print("[OV] ✅ Anime Overload watchers ready!")
    elseif GAME_ID == "anime_vanguards" then
        setupWatchers_AV()
        setupSessionTimer()
        print("[AV] ✅ Anime Vanguards watchers ready!")
    end
end)

-- ============================================================
-- [Anime Overload] Victory Trigger → log "load victory screen"
-- ============================================================
if GAME_ID == "anime_overload" then
    LogService.MessageOut:Connect(function(message, messageType)
        if not message:lower():find("load victory screen") then return end

        local now = tick()
        if now - lastVictoryTime < 30 then
            print("[OV] Skipped (cooldown)")
            return
        end
        if isSending then
            print("[OV] Skipped (already sending)")
            return
        end

        lastVictoryTime = now
        isSending = true
        roundCount = roundCount + 1
        print("[OV] 🏆 Victory! Round " .. roundCount)

        task.spawn(function()
            local waited = 0
            while waited < 5 do
                pcall(function()
                    local ct = player.PlayerGui.statusGui.endScreens.story.mid.leftBase.content
                    local a = ct.act.Text
                    if a ~= "" and a ~= "N/A" then lastAct = a end
                    local f = ct.file.Text
                    if f ~= "" and f ~= "N/A" then lastFile = f end
                    local t = ct.stats.play.content.amount.Text
                    if t ~= "" and t ~= "999999" and t ~= "00:00" and t ~= "00:00:00" then
                        lastPlayTime = t
                    end
                end)

                local hasTime = lastPlayTime ~= "00:00" and lastPlayTime ~= "00:00:00"
                local hasAct  = lastAct ~= "N/A"
                local hasFile = lastFile ~= "N/A"
                if hasTime and hasAct and hasFile then break end

                task.wait(0.1)
                waited = waited + 0.1
            end

            local rewardsStr   = (#lastRewards > 0) and table.concat(lastRewards, ", ") or "N/A"
            local sendAct      = lastAct
            local sendFile     = lastFile
            local sendPlayTime = lastPlayTime

            print("[OV] Final → Act:", sendAct, "| File:", sendFile, "| Time:", sendPlayTime, "| Rewards:", rewardsStr)

            lastRewards  = {}
            lastPlayTime = "00:00"
            lastAct      = "N/A"
            lastFile     = "N/A"
            isSending    = false

            sendToBackend({
                act      = sendAct,
                file     = sendFile,
                playTime = sendPlayTime,
                quantity = rewardsStr,
            })
        end)
    end)
end

